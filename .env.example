# ============================================================
# OKComputer — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# ── APPLICATION ──────────────────────────────────────────────
APP_NAME=OKComputer
APP_VERSION=1.0.0
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
API_HOST=0.0.0.0
API_PORT=8000

# ── DATABASE ─────────────────────────────────────────────────
# Railway provides this automatically when you add PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/okcomputer
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── REDIS ────────────────────────────────────────────────────
# Railway provides this when you add Redis
REDIS_URL=redis://localhost:6379/0

# ── ANTHROPIC AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1500

# ── BINANCE ──────────────────────────────────────────────────
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
BINANCE_TESTNET=true        # Set false for live trading
BINANCE_TESTNET_URL=https://testnet.binance.vision

# ── JWT AUTH ─────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-must-be-very-long-and-random
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── STRIPE PAYMENTS ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_GROWTH=price_growth_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# ── TRADING RISK LIMITS ──────────────────────────────────────
MAX_POSITION_SIZE_PCT=0.02      # 2% of portfolio per trade
MAX_DAILY_DRAWDOWN_PCT=0.03     # 3% max daily loss
MAX_TOTAL_DRAWDOWN_PCT=0.10     # 10% total drawdown shutdown
MIN_CONFIDENCE_THRESHOLD=0.70   # 70% confidence required
PAPER_TRADING_MODE=true         # Always start with paper trading

# ── EMAIL ────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-key
FROM_EMAIL=noreply@okcomputer.ai
ADMIN_EMAIL=your-email@gmail.com

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://okcomputer.ai
